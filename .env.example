# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# .env is gitignored — it will never be committed.

# Ollama Cloud API key (from https://ollama.com/settings/keys)
OLLAMA_API_KEY=your_ollama_api_key_here
